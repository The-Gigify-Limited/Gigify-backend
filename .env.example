# App
PORT=8000
NODE_ENV=development

# Supabase (required — app refuses to boot without these)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Cache
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=

# Google OAuth
GOOGLE_OAUTH_REDIRECT_URL=

# Resend (email)
RESEND_API_KEY=
RESEND_FROM_ADDRESS=

# Twilio (SMS / phone OTP)
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CHECKOUT_SUCCESS_URL=
STRIPE_CHECKOUT_CANCEL_URL=

# Sumsub (KYC)
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
SUMSUB_BASE_URL=
SUMSUB_LEVEL_NAME=
SUMSUB_WEBHOOK_SECRET=

# Password reset deeplink (Supabase redirects here after the user clicks the reset email)
PASSWORD_RESET_REDIRECT_URL=

# Shared secret for internal / cron-triggered endpoints
INTERNAL_JOB_SECRET=

# Bootstraps the first system admin on seed (used only by the seeder script)
DEFAULT_SYSTEM_ADMIN_PASSWORD=
