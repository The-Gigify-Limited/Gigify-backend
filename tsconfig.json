{
    "compilerOptions": {
        "target": "ES2021",
        "module": "commonjs",
        "lib": ["es6"],
        "allowJs": true,
        "outDir": "build",
        "rootDir": "src",
        "strict": true,
        "noImplicitAny": true,
        "esModuleInterop": true,
        "types": ["node", "jest"],
        "resolveJsonModule": true,
        "baseUrl": "src",
        "paths": {
            "~/*": ["./api/v1/*"],
            "@/*": ["*"],
        }
    },
    "include": ["src"]
}
